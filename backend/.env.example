GROQ_API_KEY=your_groq_api_key_here

# Gmail sender for reminder/completion emails.
# Use a Gmail App Password, not your normal Google account password.
EMAIL_FROM=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_16_character_gmail_app_password

# Google Calendar OAuth files:
# - Put credentials.json in backend/
# - Run calendar once locally to create token.json
